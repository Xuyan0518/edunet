.task-card {
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 16rpx;
  margin-bottom: 16rpx;
  background: #fff;
}

.checkbox-row {
  margin-top: 8rpx;
  gap: 10rpx;
}

.field-chip-row {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 8rpx;
}

.field-chip {
  padding: 8rpx 16rpx;
  border-radius: 999rpx;
  border: 1rpx solid #bfdbfe;
  color: #1e3a8a;
  background: #fff;
}

.field-chip-active {
  background: #dbeafe;
  border-color: #60a5fa;
}

.picker-mask {
  position: fixed;
  top: 0;
  right: 0;
  bottom: 0;
  left: 0;
  background: rgba(15, 23, 42, 0.35);
  z-index: 50;
}

.picker-panel {
  position: fixed;
  left: 24rpx;
  right: 24rpx;
  bottom: 24rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 20rpx;
  z-index: 60;
}

.picker-list {
  max-height: 520rpx;
  margin: 12rpx 0 16rpx 0;
}

.picker-item {
  padding: 16rpx 6rpx;
  border-bottom: 1rpx solid #eef2ff;
}
