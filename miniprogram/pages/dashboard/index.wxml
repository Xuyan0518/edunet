<view class="container">
  <view class="hero">
    <view class="title">仪表板</view>
    <view class="subtitle">欢迎回来，{{userName}}</view>
  </view>

  <view wx:if="{{isTeacher}}" class="card missing-card">
    <view class="row-between" bindtap="toggleMissing">
      <view class="tile-title">今日未记录学生</view>
      <view class="row-between" style="gap: 12rpx;">
        <view class="missing-badge {{missingStudents.length > 0 ? 'warn' : ''}}">
          {{missingLoading ? '...' : missingStudents.length}}
        </view>
        <view class="muted">{{missingExpanded ? '收起' : '展开'}}</view>
      </view>
    </view>
    <view class="muted" style="margin-top: 4rpx;">{{missingDate}} · 点击进入记录</view>
    <block wx:if="{{missingExpanded}}">
      <view wx:if="{{missingError}}" class="muted" style="margin-top: 12rpx;">{{missingError}}</view>
      <view wx:elif="{{!missingLoading && missingStudents.length === 0}}" class="muted" style="margin-top: 12rpx;">所有学生今日都已记录</view>
      <block wx:for="{{missingStudents}}" wx:key="id">
        <view class="missing-row" data-id="{{item.id}}" bindtap="goRecordMissing">
          <view>{{item.name}}</view>
          <view class="muted">Grade {{item.grade}}</view>
        </view>
      </block>
    </block>
  </view>

  <view wx:if="{{isTeacher}}" class="card missing-card">
    <view class="row-between" bindtap="toggleUpcoming">
      <view class="tile-title">即将到来的考试</view>
      <view class="row-between" style="gap: 12rpx;">
        <view class="missing-badge {{upcomingExams.length > 0 ? 'warn' : ''}}">
          {{upcomingLoading ? '...' : upcomingExams.length}}
        </view>
        <view class="muted">{{upcomingExpanded ? '收起' : '展开'}}</view>
      </view>
    </view>
    <view class="muted" style="margin-top: 4rpx;">提醒窗口内的考试</view>
    <block wx:if="{{upcomingExpanded}}">
      <view wx:if="{{upcomingError}}" class="muted" style="margin-top: 12rpx;">{{upcomingError}}</view>
      <view wx:elif="{{!upcomingLoading && upcomingExams.length === 0}}" class="muted" style="margin-top: 12rpx;">近期没有考试</view>
      <block wx:for="{{upcomingExams}}" wx:key="id">
        <view class="missing-row">
          <view>
            <view>{{item.title}}</view>
            <view class="muted" style="font-size: 22rpx; margin-top: 4rpx;">{{item.subtitle}}</view>
            <view wx:if="{{item.subjects}}" class="muted" style="font-size: 22rpx; margin-top: 4rpx;">{{item.subjects}}</view>
          </view>
        </view>
      </block>
    </block>
  </view>

  <view wx:if="{{isTeacher}}" class="card missing-card">
    <view class="row-between" bindtap="toggleIncomplete">
      <view class="tile-title">本周英文任务未完成学生</view>
      <view class="row-between" style="gap: 12rpx;">
        <view class="missing-badge {{incompleteStudents.length > 0 ? 'warn' : ''}}">
          {{incompleteLoading ? '...' : incompleteStudents.length}}
        </view>
        <view class="muted">{{incompleteExpanded ? '收起' : '展开'}}</view>
      </view>
    </view>
    <view class="muted" style="margin-top: 4rpx;">{{incompleteCycleStart}} → {{incompleteCycleEnd}}</view>
    <block wx:if="{{incompleteExpanded}}">
      <view wx:if="{{incompleteError}}" class="muted" style="margin-top: 12rpx;">{{incompleteError}}</view>
      <view wx:elif="{{!incompleteLoading && incompleteStudents.length === 0}}" class="muted" style="margin-top: 12rpx;">本周所有学生都已完成必做任务</view>
      <block wx:for="{{incompleteStudents}}" wx:key="id">
        <view class="missing-row" data-id="{{item.id}}" bindtap="goRecordMissing">
          <view>
            <view>{{item.name}}</view>
            <view class="muted" style="font-size: 22rpx; margin-top: 4rpx;">未完成：{{item.unmet}}</view>
          </view>
          <view class="muted">Grade {{item.grade}}</view>
        </view>
      </block>
    </block>
  </view>

  <view class="dashboard-grid">
    <view wx:if="{{isTeacher}}" class="row-two">
      <view class="card tile" bindtap="goDaily">
        <view class="tile-title">每日进度</view>
        <view class="muted">记录与查看</view>
      </view>
      <view class="card tile" bindtap="goWeekly">
        <view class="tile-title">每周汇报</view>
        <view class="muted">周报与总结</view>
      </view>
    </view>
    <view wx:if="{{!isTeacher}}" class="card tile wide" bindtap="goWeekly">
      <view class="tile-title">每周汇报</view>
      <view class="muted">周报与总结</view>
    </view>

    <view class="card tile wide" bindtap="goStudents">
      <view class="tile-title">学生</view>
      <view class="muted">查看学生与档案</view>
    </view>

    <view class="card tile wide" bindtap="goSettings">
      <view class="tile-title">设置与个人资料</view>
      <view class="muted">账号信息、偏好与退出</view>
    </view>

    <view wx:if="{{isTeacher}}" class="card tile wide" bindtap="toggleManage">
      <view class="row-between">
        <view>
          <view class="tile-title">管理入口</view>
          <view class="muted">学生与家长管理</view>
        </view>
        <view class="muted">{{manageOpen ? '收起' : '展开'}}</view>
      </view>
      <view wx:if="{{manageOpen}}" class="manage-list">
        <button class="btn-outline manage-btn" size="mini" bindtap="goStudentsManage">学生管理</button>
        <button class="btn-outline manage-btn" size="mini" bindtap="goParents">家长管理</button>
      </view>
    </view>
  </view>
</view>
