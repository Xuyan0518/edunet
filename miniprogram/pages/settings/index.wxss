.btn-outline {
  margin-top: 24rpx;
}

.small-btn {
  margin-top: 16rpx;
}

.edit-wrap {
  margin-top: 16rpx;
}

.name-input {
  width: 100%;
  box-sizing: border-box;
  border: 1px solid #d9d9d9;
  border-radius: 12rpx;
  padding: 16rpx;
  background: #fff;
}

.edit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 12rpx;
}

.inline-btn {
  flex: 1;
  margin-top: 0;
}
