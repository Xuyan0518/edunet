page {
  background: #eef4ff;
  color: #0f172a;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 32rpx;
}

.hero {
  background: linear-gradient(135deg, #dbeafe 0%, #fef3c7 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
  border: 1rpx solid #bfdbfe;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 14rpx 30rpx rgba(37, 99, 235, 0.10);
  border: 1rpx solid #e5eaf3;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.subtitle {
  color: #1e3a8a;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: linear-gradient(135deg, #2563eb 0%, #0ea5e9 100%);
  color: #fff;
  border-radius: 14rpx;
  font-weight: 600;
}

.btn-outline {
  border: 2rpx solid #93c5fd;
  color: #1e293b;
  border-radius: 14rpx;
  background: #f8fbff;
}

.section {
  margin-bottom: 24rpx;
}

.list-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #e2e8f0;
  color: #334155;
}

.muted {
  color: #64748b;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-weight: 700;
  font-size: 30rpx;
  margin-bottom: 12rpx;
}

.chip {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #e0ecff;
  color: #1e3a8a;
}

.chip-success {
  background: #dcfce7;
  color: #15803d;
}

.chip-warning {
  background: #fef3c7;
  color: #b45309;
}

.chip-muted {
  background: #e2e8f0;
  color: #475569;
}

.divider {
  height: 1rpx;
  background: #e2e8f0;
  margin: 16rpx 0;
}

.pill-group button {
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.input {
  border: 2rpx solid #bfdbfe;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  background: #fff;
}

.textarea-scroll {
  height: 240rpx;
  line-height: 1.5;
}
