.admin-student-detail-page {
  padding-bottom: 48rpx;
}

.compact-hero {
  margin-bottom: 20rpx;
}

.small-text {
  font-size: 24rpx;
}

.selected-panel {
  border-color: #fde68a;
}

.summary-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-bottom: 18rpx;
}

.summary-cell {
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  padding: 16rpx;
}

.metric-label {
  color: #64748b;
  font-size: 22rpx;
}

.summary-value {
  color: #0f172a;
  font-size: 25rpx;
  font-weight: 700;
  margin-top: 8rpx;
  word-break: break-all;
}

.edit-box {
  border: 1rpx solid #e2e8f0;
  border-radius: 18rpx;
  padding: 20rpx;
  background: #f8fafc;
  margin-top: 18rpx;
}

.compact-input {
  margin-bottom: 12rpx;
}

.picker-input {
  color: #334155;
  margin-bottom: 16rpx;
}

.save-btn {
  margin-top: 8rpx;
}

.quick-actions {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
  margin: 20rpx 0;
}

.quick-actions button {
  margin: 0;
}

.record-section {
  border-top: 1rpx solid #e2e8f0;
  padding-top: 18rpx;
  margin-top: 18rpx;
}

.record-line {
  padding: 16rpx 0;
  border-bottom: 1rpx solid #edf2f7;
}

.record-title {
  color: #0f172a;
  font-size: 26rpx;
  font-weight: 600;
}

.record-summary {
  display: -webkit-box;
  margin-top: 6rpx;
  overflow: hidden;
  -webkit-line-clamp: 2;
  -webkit-box-orient: vertical;
  font-size: 24rpx;
  line-height: 1.45;
}

.subheader {
  font-weight: 700;
  margin: 12rpx 0 8rpx;
}

button[size="mini"] {
  font-size: 24rpx;
}
