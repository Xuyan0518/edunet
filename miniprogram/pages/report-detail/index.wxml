<view class="container">
  <view class="hero" wx:if="{{report}}">
    <view class="title">{{report.title || (reportType === 'yearly' ? '学生年度学习报告' : '学生学期学习报告')}}</view>
    <view class="subtitle">
      {{report.reportType === 'yearly' ? '年度报告' : '学期报告'}} · {{report.startDate || '--'}} - {{report.endDate || '--'}}
    </view>
    <view class="row" style="gap: 10rpx; flex-wrap: wrap;">
      <view class="chip {{report.status === 'final' ? 'chip-success' : 'chip-warning'}}">{{report.status === 'final' ? '最终版' : '草稿'}}</view>
      <view class="chip {{report.visibleToParent ? 'chip-success' : 'chip-muted'}}">{{report.visibleToParent ? '已发布给家长' : '未发布'}}</view>
      <view class="chip" wx:if="{{report.year}}">{{report.year}} 年</view>
    </view>
  </view>

  <view class="section card" wx:if="{{loading}}">
    <view class="muted">加载中...</view>
  </view>

  <block wx:if="{{!loading && report}}">
    <view class="section card" wx:if="{{isManager}}">
      <view class="row" style="gap: 12rpx; flex-wrap: wrap;">
        <button class="btn-outline" size="mini" bindtap="copyMarkdown">复制 Markdown</button>
        <button wx:if="{{!previewMode}}" class="btn-outline" size="mini" bindtap="toggleVisibility" loading="{{publishing}}">
          {{report.visibleToParent ? '取消发布' : '发布给家长'}}
        </button>
      </view>
    </view>

    <view class="section card">
      <view class="section-title">Section 1：出勤与学习时间</view>
      <block wx:if="{{attendanceAndStudyTime}}">
        <view class="row-between">
          <view>出勤天数</view>
          <view class="profile-label">{{attendanceAndStudyTime.presentDays + attendanceAndStudyTime.lateDays}}</view>
        </view>
        <view class="row-between" style="margin-top: 8rpx;">
          <view>缺席天数</view>
          <view class="profile-label">{{attendanceAndStudyTime.absentDays}}</view>
        </view>
        <view class="row-between" style="margin-top: 8rpx;">
          <view>总学习时长</view>
          <view class="profile-label">{{attendanceAndStudyTime.totalStudyHours}} 小时</view>
        </view>
        <view class="row-between" style="margin-top: 8rpx;">
          <view>平均每天学习时长</view>
          <view class="profile-label">{{attendanceAndStudyTime.averageStudyHoursPerDay == null ? '--' : attendanceAndStudyTime.averageStudyHoursPerDay + ' 小时'}}</view>
        </view>
      </block>
      <view wx:else class="muted">暂无足够数据</view>
    </view>

    <view class="section card">
      <view class="section-title">Section 2：英文学习情况</view>
      <block wx:if="{{englishSummaryRows.length}}">
        <block wx:for="{{englishSummaryRows}}" wx:key="label">
          <view class="list-item">
            <view class="row-between">
              <view class="subject-title">{{item.label}}</view>
              <view class="muted">{{item.averageText}}</view>
            </view>
            <view class="muted" style="margin-top: 4rpx;">{{item.countText}}</view>
          </view>
        </block>
      </block>
      <view wx:else class="muted">暂无足够英文数据</view>
    </view>

    <view class="section card">
      <view class="section-title">Section 3：各科目学习总结</view>
      <block wx:if="{{subjectSummaryCards.length}}">
        <block wx:for="{{subjectSummaryCards}}" wx:key="subjectName">
          <view class="subject-card">
            <view class="subject-title">{{item.subjectName}}</view>
            <view class="summary-text">{{item.summary || '该阶段记录较少，暂无法形成完整趋势判断。'}}</view>
          </view>
        </block>
      </block>
      <view wx:else class="muted">暂无足够科目数据</view>
    </view>
  </block>
</view>
