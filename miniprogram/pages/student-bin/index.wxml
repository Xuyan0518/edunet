<view class="container">
  <view class="hero">
    <view class="title">回收站</view>
    <view class="subtitle">回收站记录会自动保留 30 天，超过后将被永久删除。</view>
  </view>

  <block wx:if="{{loading}}">
    <view class="card muted">加载中...</view>
  </block>

  <block wx:elif="{{empty}}">
    <view class="card empty-state">
      <view class="empty-title">暂无已删除记录</view>
      <view class="muted">删除后的记录会在这里保留 30 天。</view>
    </view>
  </block>

  <block wx:else>
    <block wx:for="{{sections}}" wx:key="key">
      <view class="section card" wx:if="{{item.items.length}}">
        <view class="section-title">{{item.title}}</view>
        <block wx:for="{{item.items}}" wx:key="recordId" wx:for-item="record">
          <view class="bin-item">
            <view class="row-between">
              <view class="bin-main">
                <view class="bin-title">{{record.title || record.typeLabel}}</view>
                <view class="muted bin-summary">{{record.summary || record.originalDateText || "无摘要"}}</view>
              </view>
              <view class="chip">{{record.typeLabel}}</view>
            </view>
            <view class="bin-meta">
              <view>原日期：{{record.originalDateText || "-"}}</view>
              <view>删除时间：{{record.deletedAtText}}</view>
              <view wx:if="{{record.deletedByName}}">删除人：{{record.deletedByName}}</view>
              <view class="retention">{{record.retentionText}}</view>
            </view>
            <view class="bin-actions">
              <button class="btn-outline action-btn" size="mini" data-type="{{record.recordType}}" data-id="{{record.recordId}}" bindtap="restoreRecord">恢复</button>
              <button class="btn-outline danger action-btn" size="mini" data-type="{{record.recordType}}" data-id="{{record.recordId}}" bindtap="permanentDelete">彻底删除</button>
            </view>
          </view>
        </block>
      </view>
    </block>
  </block>
</view>
