.row {
  margin-bottom: 12rpx;
}

.field-label {
  font-size: 24rpx;
  color: #475569;
  margin-bottom: 6rpx;
}

.field-group {
  display: flex;
  flex-direction: column;
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.daily-card {
  background: linear-gradient(180deg, #f8fbff 0%, #ffffff 100%);
  border-radius: 16rpx;
  padding: 20rpx;
  margin-top: 16rpx;
  border: 1rpx solid #dbeafe;
}

.title-small {
  font-weight: 600;
}

.daily-head {
  align-items: flex-start;
}

.daily-preview {
  margin-top: 6rpx;
  font-size: 24rpx;
}

.activity-card {
  margin-top: 12rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx solid #bfdbfe;
}

.activity-summary {
  color: #1e3a8a;
  font-weight: 600;
  margin-bottom: 10rpx;
  line-height: 1.6;
}

.section-block {
  margin-top: 10rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  border: 1rpx solid #dbeafe;
  background: #f8fbff;
}

.section-block-title {
  font-size: 24rpx;
  font-weight: 700;
  color: #1e293b;
  margin-bottom: 8rpx;
}

.mini-meta {
  display: flex;
  align-items: flex-start;
  justify-content: space-between;
  gap: 12rpx;
  font-size: 24rpx;
  color: #475569;
  margin-top: 6rpx;
}

.exercise-row {
  margin-top: 8rpx;
  padding: 12rpx;
  border-radius: 10rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
}

.exercise-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 12rpx;
}

.exercise-note {
  margin-top: 10rpx;
  padding-top: 10rpx;
  border-top: 1rpx solid #e2e8f0;
  font-size: 24rpx;
  color: #334155;
  line-height: 1.6;
}

.exercise-note-label {
  color: #64748b;
  font-size: 22rpx;
  margin-bottom: 2rpx;
}

.score-pill {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 22rpx;
  font-weight: 700;
}

.narrative-item {
  margin-top: 8rpx;
  padding: 10rpx;
  border-radius: 10rpx;
  border: 1rpx solid #e2e8f0;
  background: #ffffff;
}

.narrative-label {
  font-size: 22rpx;
  color: #64748b;
}

.narrative-value {
  margin-top: 4rpx;
  font-size: 28rpx;
  line-height: 1.5;
  color: #334155;
  word-break: break-word;
}

.section-note {
  margin-top: 8rpx;
  padding: 10rpx;
  border-radius: 10rpx;
  background: #ffffff;
  border: 1rpx solid #e2e8f0;
  color: #334155;
  line-height: 1.6;
  font-size: 24rpx;
}

.paper-title {
  margin-top: 10rpx;
  font-weight: 700;
  color: #1e293b;
}

.paper-item {
  margin-top: 8rpx;
  padding: 10rpx;
  border-radius: 10rpx;
  background: #f8fafc;
  border: 1rpx solid #e2e8f0;
}

.score-badge {
  padding: 4rpx 14rpx;
  border-radius: 999rpx;
  background: #dbeafe;
  color: #1d4ed8;
  font-size: 24rpx;
  font-weight: 700;
}

.absent-day-block {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #fff7ed;
  border: 1rpx solid #fed7aa;
}

.absent-label {
  color: #9a3412;
  font-weight: 700;
}

.paper-group-card {
  margin-top: 14rpx;
  padding: 14rpx;
  border-radius: 14rpx;
  background: #ffffff;
  border: 1rpx dashed #bfdbfe;
}

.daily-summary {
  margin-top: 12rpx;
  padding: 12rpx;
  border-radius: 12rpx;
  background: #fefce8;
  border: 1rpx solid #fde68a;
}
