<view class="container">
  <view class="title">设置</view>

  <view class="section card">
    <view class="list-item">语言：简体中文</view>
    <view class="list-item">账号：{{user.displayName || user.name || "未命名用户"}}</view>
  </view>

  <button wx:if="{{isParent}}" class="btn-outline" bindtap="subscribe">订阅通知</button>
  <button class="btn-outline" bindtap="logout">退出登录</button>
</view>
