<view class="container">
  <view class="hero">
    <view class="title">成绩</view>
    <view class="subtitle">{{student.name}}</view>
  </view>

  <view wx:if="{{isTeacher}}" class="section card">
    <view class="section-title">{{editingExamId ? "编辑考试" : "新增考试"}}</view>
    <view wx:if="{{editingExamId && editingUpdatedAtText}}" class="muted" style="margin-top: 6rpx;">
      最后修改：{{editingUpdatedAtText}} · {{editingUpdatedBy || "未知老师"}}
    </view>
    <view class="field-label">考试名称</view>
    <input class="input" placeholder="例如 WA1" value="{{examName}}" bindinput="onFieldInput" data-field="examName" />
    <view class="field-label">科目</view>
    <view class="muted" style="margin-bottom: 8rpx;">为有考试的科目设置日期；未设置日期的科目不会加入此次考试。考试结束后再回来填写分数。</view>
    <block wx:for="{{examSubjects}}" wx:key="index">
      <view class="subject-row" style="flex-wrap: wrap; row-gap: 8rpx;">
        <view class="subject-name">{{item.displayName || item.name}}</view>
        <input class="input subject-input" placeholder="分数（如 72/90）" value="{{item.score}}" data-index="{{index}}" bindinput="onSubjectScoreInput" />
        <button wx:if="{{item.isCustom}}" class="btn-outline" size="mini" data-index="{{index}}" bindtap="removeCustomSubject">删除</button>
        <view style="flex: 1 1 100%; display: flex; gap: 8rpx; align-items: center;">
          <picker mode="date" value="{{item.examDate}}" data-index="{{index}}" bindchange="onSubjectDateChange" style="flex: 1;">
            <view class="chip {{item.examDate ? '' : 'muted'}}" style="font-size: 24rpx;">{{item.examDate || "未参加此次考试 · 点击设置日期"}}</view>
          </picker>
          <button wx:if="{{item.examDate}}" class="btn-outline" size="mini" data-index="{{index}}" bindtap="clearSubjectDate">移除</button>
        </view>
      </view>
    </block>
    <view class="custom-row">
      <input class="input" placeholder="自定义科目名称" value="{{customSubjectName}}" bindinput="onFieldInput" data-field="customSubjectName" />
      <button class="btn-outline" size="mini" bindtap="addCustomSubject">添加科目</button>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <button class="btn-primary" size="mini" bindtap="saveExam">{{editingExamId ? "保存修改" : "添加考试"}}</button>
      <button wx:if="{{editingExamId}}" class="btn-outline" size="mini" bindtap="cancelEdit">取消编辑</button>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">成绩列表</view>
    <block wx:if="{{loading}}">
      <view class="muted">加载中...</view>
    </block>
    <block wx:if="{{!loading && exams.length === 0}}">
      <view class="list-item muted">暂无成绩</view>
    </block>
    <block wx:for="{{exams}}" wx:key="id">
      <view class="exam-card">
        <view class="row-between">
          <view class="grade-label">{{item.name}}</view>
          <view class="row">
            <button wx:if="{{isTeacher}}" class="btn-outline" size="mini" data-id="{{item.id}}" bindtap="startEditExam">编辑</button>
            <button wx:if="{{isTeacher}}" class="btn-outline" size="mini" data-id="{{item.id}}" bindtap="deleteExam">删除</button>
          </view>
        </view>
        <view class="muted" style="margin-top: 6rpx;">默认日期：{{item.examDate || "-"}}</view>
        <block wx:for="{{item.subjects}}" wx:key="index">
          <view class="list-item row-between">
            <view>
              <view>{{item.displayName || item.name}}</view>
              <view wx:if="{{item.examDate}}" class="muted" style="font-size: 22rpx; margin-top: 4rpx;">{{item.examDate}}</view>
            </view>
            <view class="score-side">
              <view class="chip score-chip">
                <text>{{item.score || "未录入"}}</text>
                <text wx:if="{{item.gradeDisplay}}" class="score-grade">{{item.gradeDisplay}}</text>
              </view>
              <view wx:if="{{item.percentageDisplay}}" class="score-percentage">{{item.percentageDisplay}}%</view>
            </view>
          </view>
        </block>
      </view>
    </block>
  </view>
</view>
