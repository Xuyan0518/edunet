.picker {
  padding: 16rpx;
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  background: #fff;
}

.filter-row {
  display: flex;
  gap: 12rpx;
  flex-wrap: wrap;
  margin: 12rpx 0;
}

.filter-detail {
  display: flex;
  flex-direction: column;
  gap: 8rpx;
}

.chip-active {
  background: #dbeafe;
  color: #1d4ed8;
}

.pagination {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 16rpx;
}
