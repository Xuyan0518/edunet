<view class="container">
  <view class="hero">
    <view class="title">待审批的反馈</view>
    <view class="subtitle">审核并发布老师提交的周、学期、年度反馈</view>
  </view>

  <view class="toolbar-row">
    <button class="btn-outline" size="mini" bindtap="fetchPending" loading="{{loading}}">刷新</button>
  </view>

  <block wx:if="{{pending.length === 0}}">
    <view class="section card empty-card">
      <view class="section-title">暂无待审批</view>
      <view class="muted placeholder-copy">老师提交的新反馈会显示在这里，发布后家长才可以查看。</view>
    </view>
  </block>

  <block wx:else>
    <block wx:for="{{pending}}" wx:key="id">
      <view class="section card review-card">
        <view class="row-between">
          <view>
            <view class="section-title">{{item.studentName || "未命名学生"}}</view>
            <view class="muted small-text">{{item.typeLabel}} · {{item.title}}</view>
          </view>
          <view class="review-badge">待发布</view>
        </view>
        <view class="summary-text">{{item.summary || "暂无摘要"}}</view>
        <view class="muted small-text">提交人：{{item.updatedByName || "未知"}}</view>
        <button
          class="btn-primary publish-btn"
          size="mini"
          data-id="{{item.id}}"
          data-type="{{item.type}}"
          loading="{{publishingId === item.id}}"
          disabled="{{publishingId === item.id}}"
          bindtap="publishItem"
        >发布给家长</button>
      </view>
    </block>
  </block>
</view>
