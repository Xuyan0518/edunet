.admin-page {
  padding-bottom: 48rpx;
}

.admin-hero {
  margin-bottom: 22rpx;
}

.refresh-btn {
  min-width: 112rpx;
}

.cycle-text {
  color: #475569;
  font-size: 24rpx;
}

.admin-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 18rpx;
}

.nav-card {
  min-height: 210rpx;
  border: 1rpx solid #e5eaf3;
  border-radius: 20rpx;
  background: #fff;
  padding: 24rpx;
  box-shadow: 0 10rpx 24rpx rgba(15, 23, 42, 0.06);
}

.nav-card.primary {
  border-color: #bfdbfe;
  background: #eff6ff;
}

.nav-card.warning {
  border-color: #fde68a;
  background: #fffbeb;
}

.muted-card {
  background: #f8fafc;
}

.card-label {
  color: #64748b;
  font-size: 24rpx;
  font-weight: 700;
}

.card-value {
  color: #0f172a;
  font-size: 46rpx;
  font-weight: 800;
  margin: 12rpx 0;
}

.card-copy {
  color: #475569;
  font-size: 24rpx;
  line-height: 1.4;
}

.reminder-row {
  display: flex;
  justify-content: space-between;
  color: #334155;
  font-size: 26rpx;
  font-weight: 600;
  padding-top: 18rpx;
}
