<view class="container">
  <view class="hero">
    <view class="title">每日进度</view>
    <view class="subtitle">{{student.name}} · {{selectedDate}}</view>
    <view class="row" wx:if="{{isTeacher && existingId && !isEditing}}">
      <button class="btn-outline" size="mini" bindtap="startEdit">编辑</button>
    </view>
  </view>

  <view wx:if="{{isEditable && hasDraft}}" class="section card">
    <view class="row-between">
      <view class="muted">有未发表暂存 · {{draftUpdatedAtText}}</view>
      <button class="btn-outline" size="mini" bindtap="clearDraftConfirm">清除暂存</button>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">基本信息</view>
    <view class="row-between">
      <view class="muted">学生</view>
      <view>{{student.name}}</view>
    </view>
    <view class="row-between" style="margin-top: 12rpx;">
      <view class="muted">日期</view>
      <picker mode="date" value="{{selectedDate}}" bindchange="onDateChange" disabled="{{!isEditable}}">
        <view class="chip">{{selectedDate}}</view>
      </picker>
    </view>
    <view wx:if="{{isEditable && lastUpdatedAtText}}" class="muted" style="margin-top: 8rpx;">
      最后修改：{{lastUpdatedAtText}} · {{lastUpdatedBy || "未知老师"}}
    </view>
  </view>

  <view class="section card">
    <view class="section-title">出勤</view>
    <picker mode="selector" range="{{attendanceOptions}}" bindchange="onAttendanceChange" disabled="{{!isEditable}}">
      <view class="chip">{{attendanceLabel}}</view>
    </picker>
    <view class="row-between" style="margin-top: 12rpx;">
      <view class="muted">开始时间</view>
      <view class="row">
        <input class="input" style="width: 180rpx;" placeholder="HH:mm" value="{{attendanceStart}}" bindinput="onTimeInputChange" bindblur="onTimeInputBlur" data-field="attendanceStart" disabled="{{!isEditable}}" />
        <picker mode="time" value="{{attendanceStart || '18:00'}}" bindchange="onAttendanceStartChange" disabled="{{!isEditable}}">
          <view class="chip">选择</view>
        </picker>
      </view>
    </view>
    <view class="row-between" style="margin-top: 12rpx;">
      <view class="muted">结束时间</view>
      <view class="row">
        <input class="input" style="width: 180rpx;" placeholder="HH:mm" value="{{attendanceEnd}}" bindinput="onTimeInputChange" bindblur="onTimeInputBlur" data-field="attendanceEnd" disabled="{{!isEditable}}" />
        <picker mode="time" value="{{attendanceEnd || '21:00'}}" bindchange="onAttendanceEndChange" disabled="{{!isEditable}}">
          <view class="chip">选择</view>
        </picker>
      </view>
    </view>
  </view>

  <view class="section card">
    <view class="row-between">
      <view class="section-title">活动记录</view>
    </view>
    <view wx:if="{{isTeacher && !isEditable}}" class="muted" style="margin-top: 8rpx;">
      当前为只读模式，请先点击页面顶部“编辑”再填写内容。
    </view>
    <view wx:if="{{subjectOptions.length === 0}}" class="muted">暂无科目，请先在学生详情中添加科目</view>
    <view wx:if="{{activities.length === 0}}" class="muted" style="margin-top: 8rpx;">请选择科目添加活动</view>
    <block wx:for="{{activities}}" wx:key="index">
      <view class="activity-card">
        <view class="row-between">
          <view class="field-label">{{item.subjectDisplayName || item.subjectName || "科目"}}</view>
          <view class="row">
            <button wx:if="{{item.type === 'english' && canManageEnglishTasks}}" class="btn-outline" size="mini" bindtap="openEnglishTaskManage">管理英文项目</button>
            <button wx:if="{{isEditable && !item.locked}}" class="btn-outline" size="mini" data-index="{{index}}" bindtap="removeActivity">删除</button>
          </view>
        </view>
        <block wx:if="{{item.type === 'english'}}">
          <!-- Editing -->
          <view class="english-section" wx:if="{{item.english.editing.uiEnabled}}">
            <view class="english-section-header" data-index="{{index}}" data-subfield="editing" bindtap="toggleEnglishSection">
              <view class="english-section-title">{{item.english.editing.uiLabel || '改错 (Editing)'}}</view>
              <view class="english-section-meta">
                <view class="english-section-summary">{{item.english.editing.uiSummary}}</view>
                <view class="english-section-toggle">{{item.english.editing.uiExpanded ? '收起 ▾' : '展开 ▸'}}</view>
              </view>
            </view>
            <block wx:if="{{item.english.editing.uiExpanded}}">
              <view class="english-section-body">
                <view class="row score-row" wx:if="{{item.english.editing.uiFieldsUsed.indexOf('practiceCount') !== -1}}">
                  <view class="score-cell">
                    <view class="muted">练习数</view>
                    <input class="input score-input" type="number" placeholder="0" value="{{item.english.editing.exerciseCount}}" data-index="{{index}}" data-subfield="editing" data-key="exerciseCount" bindinput="onEnglishCountChange" disabled="{{!isEditable}}" />
                  </view>
                </view>
                <block wx:for="{{item.english.editing.exercises}}" wx:for-item="ex" wx:for-index="exIdx" wx:key="exIdx">
                  <view class="exercise-block" style="margin-top: 10rpx; padding: 8rpx 0;">
                    <view class="muted">练习 {{exIdx + 1}}</view>
                    <view class="row score-row" wx:if="{{item.english.editing.uiFieldsUsed.indexOf('score') !== -1}}">
                      <view class="score-cell">
                        <view class="muted">得分 / 满分</view>
                        <input class="input score-input" type="digit" placeholder="-" value="{{ex.score}}" data-index="{{index}}" data-subfield="editing" data-exercise-index="{{exIdx}}" bindinput="onExerciseScoreChange" disabled="{{!isEditable}}" />
                      </view>
                      <view class="muted">/</view>
                      <view class="score-cell">
                        <input class="input score-input" type="digit" placeholder="100" value="{{ex.totalScore}}" data-index="{{index}}" data-subfield="editing" data-exercise-index="{{exIdx}}" bindinput="onExerciseTotalScoreChange" disabled="{{!isEditable}}" />
                      </view>
                    </view>
                    <textarea wx:if="{{ex.showProblems && item.english.editing.uiFieldsUsed.indexOf('problems') !== -1}}" class="input" style="min-height: 120rpx; margin-top: 16rpx;" placeholder="出现的问题（非满分必填）" value="{{ex.problems}}" data-index="{{index}}" data-subfield="editing" data-exercise-index="{{exIdx}}" bindinput="onExerciseProblemsChange" disabled="{{!isEditable}}" />
                  </view>
                </block>
                <view wx:if="{{item.english.editing.anyImperfect}}">
                  <view class="field-label">失分点 (可多选)</view>
                  <view class="chips-row">
                    <view wx:for="{{item.english.editing.chips}}" wx:for-item="chip" wx:for-index="chipIdx" wx:key="id" class="chip-tap {{chip.selected ? 'chip-selected' : ''}}" data-index="{{index}}" data-subfield="editing" data-id="{{chip.id}}" bindtap="onLossPointToggle">{{chip.label}}</view>
                  </view>
                  <input class="input" placeholder="其他失分点 (可选)" value="{{item.english.editing.otherLossPointText}}" data-index="{{index}}" data-subfield="editing" bindinput="onEnglishOtherChange" disabled="{{!isEditable}}" />
                </view>
              </view>
            </block>
          </view>

          <!-- Reading -->
          <view class="english-section" wx:if="{{item.english.reading.uiEnabled}}">
            <view class="english-section-header" data-index="{{index}}" data-subfield="reading" bindtap="toggleEnglishSection">
              <view class="english-section-title">{{item.english.reading.uiLabel || '阅读理解 (Reading)'}}</view>
              <view class="english-section-meta">
                <view class="english-section-summary">{{item.english.reading.uiSummary}}</view>
                <view class="english-section-toggle">{{item.english.reading.uiExpanded ? '收起 ▾' : '展开 ▸'}}</view>
              </view>
            </view>
            <block wx:if="{{item.english.reading.uiExpanded}}">
              <view class="english-section-body">
                <view class="row score-row" wx:if="{{item.english.reading.uiFieldsUsed.indexOf('practiceCount') !== -1}}">
                  <view class="score-cell">
                    <view class="muted">文章数</view>
                    <input class="input score-input" type="number" placeholder="0" value="{{item.english.reading.articleCount}}" data-index="{{index}}" data-subfield="reading" data-key="articleCount" bindinput="onEnglishCountChange" disabled="{{!isEditable}}" />
                  </view>
                </view>
                <block wx:for="{{item.english.reading.exercises}}" wx:for-item="ex" wx:for-index="exIdx" wx:key="exIdx">
                  <view class="exercise-block" style="margin-top: 10rpx; padding: 8rpx 0;">
                    <view class="muted">文章 {{exIdx + 1}}</view>
                    <view class="row score-row" wx:if="{{item.english.reading.uiFieldsUsed.indexOf('score') !== -1}}">
                      <view class="score-cell">
                        <view class="muted">得分 / 满分</view>
                        <input class="input score-input" type="digit" placeholder="-" value="{{ex.score}}" data-index="{{index}}" data-subfield="reading" data-exercise-index="{{exIdx}}" bindinput="onExerciseScoreChange" disabled="{{!isEditable}}" />
                      </view>
                      <view class="muted">/</view>
                      <view class="score-cell">
                        <input class="input score-input" type="digit" placeholder="100" value="{{ex.totalScore}}" data-index="{{index}}" data-subfield="reading" data-exercise-index="{{exIdx}}" bindinput="onExerciseTotalScoreChange" disabled="{{!isEditable}}" />
                      </view>
                    </view>
                    <textarea wx:if="{{ex.showProblems && item.english.reading.uiFieldsUsed.indexOf('problems') !== -1}}" class="input" style="min-height: 120rpx; margin-top: 16rpx;" placeholder="出现的问题（非满分必填）" value="{{ex.problems}}" data-index="{{index}}" data-subfield="reading" data-exercise-index="{{exIdx}}" bindinput="onExerciseProblemsChange" disabled="{{!isEditable}}" />
                  </view>
                </block>
                <view wx:if="{{item.english.reading.anyImperfect}}">
                  <view class="field-label">失分点 (可多选)</view>
                  <view class="chips-row">
                    <view wx:for="{{item.english.reading.chips}}" wx:for-item="chip" wx:for-index="chipIdx" wx:key="id" class="chip-tap {{chip.selected ? 'chip-selected' : ''}}" data-index="{{index}}" data-subfield="reading" data-id="{{chip.id}}" bindtap="onLossPointToggle">{{chip.label}}</view>
                  </view>
                  <input class="input" placeholder="其他失分点 (可选)" value="{{item.english.reading.otherLossPointText}}" data-index="{{index}}" data-subfield="reading" bindinput="onEnglishOtherChange" disabled="{{!isEditable}}" />
                </view>
              </view>
            </block>
          </view>

          <!-- Grammar -->
          <view class="english-section" wx:if="{{item.english.grammar.uiEnabled}}">
            <view class="english-section-header" data-index="{{index}}" data-subfield="grammar" bindtap="toggleEnglishSection">
              <view class="english-section-title">{{item.english.grammar.uiLabel || '语法 (Grammar)'}}</view>
              <view class="english-section-meta">
                <view class="english-section-summary">{{item.english.grammar.uiSummary}}</view>
                <view class="english-section-toggle">{{item.english.grammar.uiExpanded ? '收起 ▾' : '展开 ▸'}}</view>
              </view>
            </view>
            <block wx:if="{{item.english.grammar.uiExpanded}}">
              <view class="english-section-body">
                <view class="row score-row" wx:if="{{item.english.grammar.uiFieldsUsed.indexOf('practiceCount') !== -1}}">
                  <view class="score-cell">
                    <view class="muted">练习数</view>
                    <input class="input score-input" type="number" placeholder="0" value="{{item.english.grammar.exerciseCount}}" data-index="{{index}}" data-subfield="grammar" data-key="exerciseCount" bindinput="onEnglishCountChange" disabled="{{!isEditable}}" />
                  </view>
                </view>
                <block wx:for="{{item.english.grammar.exercises}}" wx:for-item="ex" wx:for-index="exIdx" wx:key="exIdx">
                  <view class="exercise-block" style="margin-top: 10rpx; padding: 8rpx 0;">
                    <view class="muted">练习 {{exIdx + 1}}</view>
                    <view class="row score-row" wx:if="{{item.english.grammar.uiFieldsUsed.indexOf('score') !== -1}}">
                      <view class="score-cell">
                        <view class="muted">得分 / 满分</view>
                        <input class="input score-input" type="digit" placeholder="-" value="{{ex.score}}" data-index="{{index}}" data-subfield="grammar" data-exercise-index="{{exIdx}}" bindinput="onExerciseScoreChange" disabled="{{!isEditable}}" />
                      </view>
                      <view class="muted">/</view>
                      <view class="score-cell">
                        <input class="input score-input" type="digit" placeholder="100" value="{{ex.totalScore}}" data-index="{{index}}" data-subfield="grammar" data-exercise-index="{{exIdx}}" bindinput="onExerciseTotalScoreChange" disabled="{{!isEditable}}" />
                      </view>
                    </view>
                    <textarea wx:if="{{ex.showProblems && item.english.grammar.uiFieldsUsed.indexOf('problems') !== -1}}" class="input" style="min-height: 120rpx; margin-top: 16rpx;" placeholder="出现的问题（非满分必填）" value="{{ex.problems}}" data-index="{{index}}" data-subfield="grammar" data-exercise-index="{{exIdx}}" bindinput="onExerciseProblemsChange" disabled="{{!isEditable}}" />
                  </view>
                </block>
                <view wx:if="{{item.english.grammar.anyImperfect}}">
                  <view class="field-label">失分点 (可多选)</view>
                  <view class="chips-row">
                    <view wx:for="{{item.english.grammar.chips}}" wx:for-item="chip" wx:for-index="chipIdx" wx:key="id" class="chip-tap {{chip.selected ? 'chip-selected' : ''}}" data-index="{{index}}" data-subfield="grammar" data-id="{{chip.id}}" bindtap="onLossPointToggle">{{chip.label}}</view>
                  </view>
                  <input class="input" placeholder="其他失分点 (可选)" value="{{item.english.grammar.otherLossPointText}}" data-index="{{index}}" data-subfield="grammar" bindinput="onEnglishOtherChange" disabled="{{!isEditable}}" />
                </view>
              </view>
            </block>
          </view>

          <!-- Vocab -->
          <view class="english-section" wx:if="{{item.english.vocab.uiEnabled}}">
            <view class="english-section-header" data-index="{{index}}" data-subfield="vocab" bindtap="toggleEnglishSection">
              <view class="english-section-title">{{item.english.vocab.uiLabel || '词汇 (Vocab)'}}</view>
              <view class="english-section-meta">
                <view class="english-section-summary">{{item.english.vocab.uiSummary}}</view>
                <view class="english-section-toggle">{{item.english.vocab.uiExpanded ? '收起 ▾' : '展开 ▸'}}</view>
              </view>
            </view>
            <block wx:if="{{item.english.vocab.uiExpanded}}">
              <view class="english-section-body">
                <view class="row score-row" wx:if="{{item.english.vocab.uiFieldsUsed.indexOf('practiceCount') !== -1}}">
                  <view class="score-cell">
                    <view class="muted">单词数</view>
                    <input class="input score-input" type="number" placeholder="0" value="{{item.english.vocab.vocabularyWordCount}}" data-index="{{index}}" data-subfield="vocab" data-key="vocabularyWordCount" bindinput="onEnglishCountChange" disabled="{{!isEditable}}" />
                  </view>
                  <view class="score-cell">
                    <view class="muted">句子数</view>
                    <input class="input score-input" type="number" placeholder="0" value="{{item.english.vocab.vocabularySentenceCount}}" data-index="{{index}}" data-subfield="vocab" data-key="vocabularySentenceCount" bindinput="onEnglishCountChange" disabled="{{!isEditable}}" />
                  </view>
                </view>
              </view>
            </block>
          </view>

          <!-- Recitation -->
          <view class="english-section" wx:if="{{item.english.recitation.uiEnabled}}">
            <view class="english-section-header" data-index="{{index}}" data-subfield="recitation" bindtap="toggleEnglishSection">
              <view class="english-section-title">{{item.english.recitation.uiLabel || '单词句子背诵 (Recitation)'}}</view>
              <view class="english-section-meta">
                <view class="english-section-summary">{{item.english.recitation.uiSummary}}</view>
                <view class="english-section-toggle">{{item.english.recitation.uiExpanded ? '收起 ▾' : '展开 ▸'}}</view>
              </view>
            </view>
            <block wx:if="{{item.english.recitation.uiExpanded}}">
              <view class="english-section-body">
                <input wx:if="{{item.english.recitation.uiFieldsUsed.indexOf('problems') !== -1}}" class="input" placeholder="背诵说明" value="{{item.english.recitation.text}}" data-index="{{index}}" data-subfield="recitation" bindinput="onEnglishTextChange" disabled="{{!isEditable}}" />
              </view>
            </block>
          </view>

          <!-- Essay -->
          <view class="english-section" wx:if="{{item.english.essay.uiEnabled}}">
            <view class="english-section-header" data-index="{{index}}" data-subfield="essay" bindtap="toggleEnglishSection">
              <view class="english-section-title">{{item.english.essay.uiLabel || '作文 (Essay)'}}</view>
              <view class="english-section-meta">
                <view class="english-section-summary">{{item.english.essay.uiSummary}}</view>
                <view class="english-section-toggle">{{item.english.essay.uiExpanded ? '收起 ▾' : '展开 ▸'}}</view>
              </view>
            </view>
            <block wx:if="{{item.english.essay.uiExpanded}}">
              <view class="english-section-body">
                <input wx:if="{{item.english.essay.uiFieldsUsed.indexOf('problems') !== -1}}" class="input" placeholder="题目" value="{{item.english.essay.title}}" data-index="{{index}}" bindinput="onEssayTitleChange" disabled="{{!isEditable}}" />
                <view class="row score-row" wx:if="{{item.english.essay.uiFieldsUsed.indexOf('score') !== -1}}">
                  <view class="score-cell">
                    <view class="muted">得分 / 满分</view>
                    <input class="input score-input" type="digit" placeholder="-" value="{{item.english.essay.score}}" data-index="{{index}}" data-subfield="essay" bindinput="onEnglishScoreChange" disabled="{{!isEditable}}" />
                  </view>
                  <view class="muted">/</view>
                  <view class="score-cell">
                    <input class="input score-input" type="digit" placeholder="100" value="{{item.english.essay.totalScore}}" data-index="{{index}}" data-subfield="essay" bindinput="onEnglishTotalScoreChange" disabled="{{!isEditable}}" />
                  </view>
                  <checkbox-group class="score-cell" data-index="{{index}}" bindchange="onEssayCompletedToggle">
                    <label class="row">
                      <checkbox value="done" checked="{{item.english.essay ? item.english.essay.completed : false}}" disabled="{{!isEditable}}" />
                      <view class="muted">已完成</view>
                    </label>
                  </checkbox-group>
                </view>
                <input wx:if="{{item.english.essay.uiFieldsUsed.indexOf('problems') !== -1 && item.english.essay.showProblems}}" class="input" placeholder="出现的问题（非满分必填）" value="{{item.english.essay.text}}" data-index="{{index}}" data-subfield="essay" bindinput="onEnglishTextChange" disabled="{{!isEditable}}" />
              </view>
            </block>
          </view>

          <block wx:for="{{item.customEnglishTasks}}" wx:for-item="task" wx:for-index="taskIndex" wx:key="taskId">
            <view class="english-section">
              <view class="english-section-header" data-index="{{index}}" data-task-index="{{taskIndex}}" bindtap="toggleCustomEnglishTask">
                <view class="english-section-title">{{task.displayName}}</view>
                <view class="english-section-meta">
                  <view class="english-section-summary">目标 {{task.targetCount}} 次</view>
                  <view class="english-section-toggle">{{task.uiExpanded ? '收起 ▾' : '展开 ▸'}}</view>
                </view>
              </view>
              <block wx:if="{{task.uiExpanded}}">
                <view class="english-section-body">
                  <view class="row score-row" wx:if="{{task.fieldsUsed && task.fieldsUsed.indexOf('practiceCount') !== -1}}">
                    <view class="score-cell">
                      <view class="muted">练习数</view>
                      <input class="input score-input" type="number" value="{{task.practiceCount}}" data-index="{{index}}" data-task-index="{{taskIndex}}" bindinput="onCustomTaskCountInput" disabled="{{!isEditable}}" />
                    </view>
                  </view>
                  <block wx:if="{{task.fieldsUsed && task.fieldsUsed.indexOf('practiceCount') !== -1}}">
                    <block wx:for="{{task.exercises}}" wx:for-item="ex" wx:for-index="exIdx" wx:key="exIdx">
                      <view class="exercise-block" style="margin-top: 10rpx; padding: 8rpx 0;">
                        <view class="muted">练习 {{exIdx + 1}}</view>
                        <view class="row score-row" wx:if="{{task.fieldsUsed.indexOf('score') !== -1}}">
                          <view class="score-cell">
                            <view class="muted">得分 / 满分</view>
                            <input class="input score-input" type="digit" value="{{ex.score}}" data-index="{{index}}" data-task-index="{{taskIndex}}" data-exercise-index="{{exIdx}}" bindinput="onCustomTaskExerciseScoreInput" disabled="{{!isEditable}}" />
                          </view>
                          <view class="muted">/</view>
                          <view class="score-cell">
                            <input class="input score-input" type="digit" placeholder="100" value="{{ex.totalScore}}" data-index="{{index}}" data-task-index="{{taskIndex}}" data-exercise-index="{{exIdx}}" bindinput="onCustomTaskExerciseTotalInput" disabled="{{!isEditable}}" />
                          </view>
                        </view>
                        <textarea wx:if="{{task.fieldsUsed.indexOf('problems') !== -1 && ex.showProblems}}" class="input" style="min-height: 120rpx; margin-top: 16rpx;" placeholder="出现的问题（非满分必填）" value="{{ex.problems}}" data-index="{{index}}" data-task-index="{{taskIndex}}" data-exercise-index="{{exIdx}}" bindinput="onCustomTaskExerciseProblemsInput" disabled="{{!isEditable}}" />
                      </view>
                    </block>
                  </block>
                  <view class="row score-row" wx:if="{{task.fieldsUsed && task.fieldsUsed.indexOf('practiceCount') === -1 && task.fieldsUsed.indexOf('score') !== -1}}">
                    <view class="score-cell">
                      <view class="muted">得分 / 满分</view>
                      <input class="input score-input" type="digit" value="{{task.score}}" data-index="{{index}}" data-task-index="{{taskIndex}}" bindinput="onCustomTaskScoreInput" disabled="{{!isEditable}}" />
                    </view>
                    <view class="muted">/</view>
                    <view class="score-cell">
                      <input class="input score-input" type="digit" value="{{task.maxScore}}" data-index="{{index}}" data-task-index="{{taskIndex}}" bindinput="onCustomTaskMaxScoreInput" disabled="{{!isEditable}}" />
                    </view>
                  </view>
                  <textarea wx:if="{{task.fieldsUsed && task.fieldsUsed.indexOf('practiceCount') === -1 && task.fieldsUsed.indexOf('problems') !== -1 && task.score !== null && task.maxScore !== null && task.score < task.maxScore}}" class="input" style="min-height: 120rpx; margin-top: 16rpx;" placeholder="出现的问题（非满分必填）" value="{{task.problems}}" data-index="{{index}}" data-task-index="{{taskIndex}}" bindinput="onCustomTaskProblemsInput" disabled="{{!isEditable}}" />
                </view>
              </block>
            </view>
          </block>

          <view class="field-label">试卷练习</view>
          <block wx:if="{{item.papers.length === 0}}">
            <view class="muted">暂无试卷</view>
          </block>
          <block wx:for="{{item.papers}}" wx:for-item="paper" wx:for-index="paperIndex" wx:key="paperIndex">
            <view class="paper-card">
              <view class="row-between">
                <view class="paper-title">试卷</view>
                <button wx:if="{{isEditable}}" class="btn-outline" size="mini" data-index="{{index}}" data-paper="{{paperIndex}}" bindtap="removePaper">删除</button>
              </view>

              <view class="field-label" style="margin-top: 8rpx;">试卷类型</view>
              <view class="row-between">
                <picker mode="selector" range="{{paperTypeOptions}}" value="{{paper.typeIndex}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindchange="onPaperTypePick" disabled="{{!isEditable}}">
                  <view class="chip">{{paperTypeOptions[paper.typeIndex]}}</view>
                </picker>
                <button wx:if="{{isEditable}}" class="btn-outline" size="mini" data-index="{{index}}" data-paper="{{paperIndex}}" bindtap="addPaperType">新增类型</button>
              </view>

              <view class="field-label" style="margin-top: 8rpx;">学校名称</view>
              <view class="row-between">
                <picker mode="selector" range="{{paperSchoolOptions}}" value="{{paper.schoolIndex}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindchange="onPaperSchoolPick" disabled="{{!isEditable}}">
                  <view class="chip">{{paperSchoolOptions[paper.schoolIndex]}}</view>
                </picker>
                <button wx:if="{{isEditable}}" class="btn-outline" size="mini" data-index="{{index}}" data-paper="{{paperIndex}}" bindtap="addPaperSchool">新增学校</button>
              </view>

              <view class="field-label" style="margin-top: 8rpx;">试卷描述</view>
              <input class="input" placeholder="例如：试卷一" value="{{paper.description}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindinput="onPaperChange" data-field="description" disabled="{{!isEditable}}" />

              <view class="field-label" style="margin-top: 8rpx;">做得好的地方 *</view>
              <textarea class="input textarea-scroll" style="height: 130rpx;" placeholder="例如：审题更仔细，计算更稳定" value="{{paper.strengths}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindinput="onPaperChange" data-field="strengths" disabled="{{!isEditable}}" maxlength="-1"></textarea>

              <view class="field-label" style="margin-top: 8rpx;">需要改进的地方 *</view>
              <textarea class="input textarea-scroll" style="height: 130rpx;" placeholder="例如：步骤书写不完整，时间分配需优化" value="{{paper.improvements}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindinput="onPaperChange" data-field="improvements" disabled="{{!isEditable}}" maxlength="-1"></textarea>

              <view class="field-label" style="margin-top: 8rpx;">分数</view>
              <view class="row paper-score">
                <input class="input score-input" placeholder="得分" value="{{paper.score}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindinput="onPaperChange" data-field="score" disabled="{{!isEditable}}" />
                <view class="muted">/</view>
                <input class="input score-input" placeholder="总分" value="{{paper.total}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindinput="onPaperChange" data-field="total" disabled="{{!isEditable}}" />
              </view>
            </view>
          </block>
          <button wx:if="{{isEditable}}" class="btn-outline" size="mini" data-index="{{index}}" bindtap="addPaper">添加试卷</button>
        </block>
        <block wx:else>
          <view class="field-label">学生具体做了什么 *</view>
          <textarea class="input textarea-scroll" placeholder="例如：完成章节练习、错题订正、口头复述知识点" value="{{item.taskSummary}}" data-index="{{index}}" bindinput="onActivityChange" data-field="taskSummary" disabled="{{!isEditable}}" maxlength="-1"></textarea>
          <view class="field-label">做得好的地方 *</view>
          <textarea class="input textarea-scroll" placeholder="例如：概念理解扎实，题目完成效率高" value="{{item.strengths}}" data-index="{{index}}" bindinput="onActivityChange" data-field="strengths" disabled="{{!isEditable}}" maxlength="-1"></textarea>
          <view class="field-label">需要进步的地方 *</view>
          <textarea class="input textarea-scroll" placeholder="例如：审题细节和术语表达还需加强" value="{{item.improvements}}" data-index="{{index}}" bindinput="onActivityChange" data-field="improvements" disabled="{{!isEditable}}" maxlength="-1"></textarea>
          <view class="field-label">试卷练习</view>
          <block wx:if="{{item.papers.length === 0}}">
            <view class="muted">暂无试卷</view>
          </block>
          <block wx:for="{{item.papers}}" wx:for-item="paper" wx:for-index="paperIndex" wx:key="paperIndex">
            <view class="paper-card">
              <view class="row-between">
                <view class="paper-title">试卷</view>
                <button wx:if="{{isEditable}}" class="btn-outline" size="mini" data-index="{{index}}" data-paper="{{paperIndex}}" bindtap="removePaper">删除</button>
              </view>

              <view class="field-label" style="margin-top: 8rpx;">试卷类型</view>
              <view class="row-between">
                <picker mode="selector" range="{{paperTypeOptions}}" value="{{paper.typeIndex}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindchange="onPaperTypePick" disabled="{{!isEditable}}">
                  <view class="chip">{{paperTypeOptions[paper.typeIndex]}}</view>
                </picker>
                <button wx:if="{{isEditable}}" class="btn-outline" size="mini" data-index="{{index}}" data-paper="{{paperIndex}}" bindtap="addPaperType">新增类型</button>
              </view>

              <view class="field-label" style="margin-top: 8rpx;">学校名称</view>
              <view class="row-between">
                <picker mode="selector" range="{{paperSchoolOptions}}" value="{{paper.schoolIndex}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindchange="onPaperSchoolPick" disabled="{{!isEditable}}">
                  <view class="chip">{{paperSchoolOptions[paper.schoolIndex]}}</view>
                </picker>
                <button wx:if="{{isEditable}}" class="btn-outline" size="mini" data-index="{{index}}" data-paper="{{paperIndex}}" bindtap="addPaperSchool">新增学校</button>
              </view>

              <view class="field-label" style="margin-top: 8rpx;">试卷描述</view>
              <input class="input" placeholder="例如：试卷一" value="{{paper.description}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindinput="onPaperChange" data-field="description" disabled="{{!isEditable}}" />

              <view class="field-label" style="margin-top: 8rpx;">做得好的地方 *</view>
              <textarea class="input textarea-scroll" style="height: 130rpx;" placeholder="例如：审题更仔细，计算更稳定" value="{{paper.strengths}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindinput="onPaperChange" data-field="strengths" disabled="{{!isEditable}}" maxlength="-1"></textarea>

              <view class="field-label" style="margin-top: 8rpx;">需要改进的地方 *</view>
              <textarea class="input textarea-scroll" style="height: 130rpx;" placeholder="例如：步骤书写不完整，时间分配需优化" value="{{paper.improvements}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindinput="onPaperChange" data-field="improvements" disabled="{{!isEditable}}" maxlength="-1"></textarea>

              <view class="field-label" style="margin-top: 8rpx;">分数</view>
              <view class="row paper-score">
                <input class="input score-input" placeholder="得分" value="{{paper.score}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindinput="onPaperChange" data-field="score" disabled="{{!isEditable}}" />
                <view class="muted">/</view>
                <input class="input score-input" placeholder="总分" value="{{paper.total}}" data-index="{{index}}" data-paper="{{paperIndex}}" bindinput="onPaperChange" data-field="total" disabled="{{!isEditable}}" />
              </view>
            </view>
          </block>
          <button wx:if="{{isEditable}}" class="btn-outline" size="mini" data-index="{{index}}" bindtap="addPaper">添加试卷</button>
        </block>
      </view>
      <view class="divider"></view>
    </block>
    <view class="row" wx:if="{{isEditable && subjectOptions.length}}">
      <picker mode="selector" range="{{subjectOptions}}" bindchange="onSubjectPick">
        <button class="btn-outline" size="mini">添加科目</button>
      </picker>
    </view>
  </view>

  <view class="section card">
    <view class="row-between">
      <view class="section-title">章节进度</view>
      <view class="chip">{{topicProgressSubjects.length}} 科目</view>
    </view>
    <view class="muted" style="margin-bottom: 10rpx;">在填写每日进度时可直接更新章节完成情况，学生档案会同步显示。</view>
    <block wx:if="{{topicProgressSubjects.length === 0}}">
      <view class="muted">暂无章节数据，请先在学生档案中同步科目与主题</view>
    </block>
    <block wx:for="{{topicProgressSubjects}}" wx:key="subjectId">
      <view class="topic-subject-card">
        <view class="row-between subject-header" bindtap="toggleTopicProgressSubject" data-id="{{item.subject.id}}">
          <view class="subject-text">
            <view class="subject-title">{{item.subject.displayName || item.subject.name}}</view>
            <view class="muted subject-code">{{item.subject.code}}</view>
          </view>
          <view class="row">
            <view class="chip">{{item.totalCount}} 主题</view>
            <view class="muted">{{topicProgressExpandedSubjects[item.subject.id] ? '收起' : '展开'}}</view>
          </view>
        </view>
        <block wx:if="{{topicProgressExpandedSubjects[item.subject.id]}}">
          <view class="divider"></view>
          <block wx:for="{{item.topics}}" wx:key="id">
            <view class="topic-row">
              <view class="row-between topic-header">
                <view class="topic-title">{{item.code}} {{item.displayTitle || item.title}}</view>
                <view class="row topic-meta">
                  <view class="chip {{item.statusClass}}">{{item.statusLabel}}</view>
                  <view wx:if="{{item.children.length}}" class="muted" bindtap="toggleTopicProgressTopic" data-id="{{item.id}}">
                    {{topicProgressExpandedTopics[item.id] ? '收起' : '展开'}}
                  </view>
                </view>
              </view>
              <view class="pill-group">
                <button
                  size="mini"
                  class="pill-btn {{item.definitionRecited ? 'pill-active' : ''}}"
                  data-topic="{{item.id}}"
                  data-condition="definitionRecited"
                  data-value="{{item.definitionRecited}}"
                  bindtap="updateTopicCondition"
                  disabled="{{!isEditable}}"
                >定义背诵</button>
                <button
                  size="mini"
                  class="pill-btn {{item.chapterExerciseCompleted ? 'pill-active' : ''}}"
                  data-topic="{{item.id}}"
                  data-condition="chapterExerciseCompleted"
                  data-value="{{item.chapterExerciseCompleted}}"
                  bindtap="updateTopicCondition"
                  disabled="{{!isEditable}}"
                >章节练习</button>
              </view>
              <block wx:if="{{topicProgressExpandedTopics[item.id]}}">
                <block wx:for="{{item.children}}" wx:key="id">
                  <view class="topic-row subtopic">
                    <view class="row-between topic-header">
                      <view class="topic-title">{{item.code}} {{item.displayTitle || item.title}}</view>
                      <view class="chip {{item.statusClass}}">{{item.statusLabel}}</view>
                    </view>
                    <view class="pill-group">
                      <button
                        size="mini"
                        class="pill-btn {{item.definitionRecited ? 'pill-active' : ''}}"
                        data-topic="{{item.id}}"
                        data-condition="definitionRecited"
                        data-value="{{item.definitionRecited}}"
                        bindtap="updateTopicCondition"
                        disabled="{{!isEditable}}"
                      >定义背诵</button>
                      <button
                        size="mini"
                        class="pill-btn {{item.chapterExerciseCompleted ? 'pill-active' : ''}}"
                        data-topic="{{item.id}}"
                        data-condition="chapterExerciseCompleted"
                        data-value="{{item.chapterExerciseCompleted}}"
                        bindtap="updateTopicCondition"
                        disabled="{{!isEditable}}"
                      >章节练习</button>
                    </view>
                  </view>
                </block>
              </block>
            </view>
          </block>
        </block>
      </view>
    </block>
  </view>

  <view class="section card">
    <view class="section-title">总结</view>
    <textarea class="input textarea-scroll" placeholder="填写当日总结..." value="{{summary}}" bindinput="onFieldInput" data-field="summary" disabled="{{!isEditable}}" maxlength="-1"></textarea>
  </view>

  <view class="row">
    <button wx:if="{{isEditable}}" class="btn-outline" bindtap="cancelEdit">取消</button>
    <button wx:if="{{isEditable}}" class="btn-outline" loading="{{draftSaving}}" disabled="{{draftSaving || publishing}}" bindtap="saveLocalDraft">暂存</button>
    <button wx:if="{{isEditable}}" class="btn-primary" loading="{{publishing}}" disabled="{{publishing}}" bindtap="publish">发表</button>
  </view>

  <button wx:if="{{existingId && isTeacher}}" class="btn-outline" bindtap="deleteEntry">删除记录</button>
</view>
