<view class="container">
  <view class="hero">
    <view class="title">{{mode === 'edit' ? '编辑科目' : '新增科目'}}</view>
    <view class="subtitle">一次填写科目基础信息，并可选添加章节（可后续再补）</view>
  </view>

  <view class="section card" wx:if="{{loading}}">
    <view class="muted">加载中...</view>
  </view>

  <view wx:else>
    <view class="section card">
      <view class="field-label">层级</view>
      <picker mode="selector" range="{{levelOptions}}" value="{{levelIndex}}" bindchange="onLevelChange">
        <view class="chip">{{levelOptions[levelIndex] || '请选择层级'}}</view>
      </picker>

      <view class="field-label" style="margin-top: 12rpx;">中文名</view>
      <input class="input" placeholder="例如：物理" value="{{chineseName}}" data-field="chineseName" bindinput="onFieldInput" />

      <view class="field-label" style="margin-top: 12rpx;">英文名（可选）</view>
      <input class="input" placeholder="例如：Physics" value="{{englishName}}" data-field="englishName" bindinput="onFieldInput" />

      <view class="field-label" style="margin-top: 12rpx;">Code（可选，不填自动生成）</view>
      <input class="input" placeholder="例如：PHYSICS" value="{{code}}" data-field="code" bindinput="onFieldInput" />

      <view class="field-label" style="margin-top: 12rpx;">排序（可选）</view>
      <input class="input" type="number" placeholder="0" value="{{sortOrder}}" data-field="sortOrder" bindinput="onFieldInput" />

      <checkbox-group bindchange="onRequiredChange" style="margin-top: 14rpx;">
        <label class="row">
          <checkbox value="required" checked="{{isRequired}}" />
          <view>设为必选</view>
        </label>
      </checkbox-group>
    </view>

    <view class="section card">
      <view class="row-between">
        <view class="section-title">章节（可先空）</view>
        <button class="btn-outline" size="mini" bindtap="addTopicDraft">添加章节</button>
      </view>
      <view class="muted" wx:if="{{topics.length === 0}}">暂未添加章节，保存后也可随时回来添加。</view>

      <block wx:for="{{topics}}" wx:key="id" wx:for-item="topic" wx:for-index="index">
        <view class="topic-card" wx:if="{{!topic._deleted}}">
          <view class="row-between">
            <view class="field-label">章节 {{index + 1}}</view>
            <button class="btn-outline" size="mini" data-index="{{index}}" bindtap="removeTopicDraft">删除</button>
          </view>

          <view class="field-label">章节名</view>
          <input class="input" placeholder="例如：Kinematics" value="{{topic.title}}" data-index="{{index}}" data-field="title" bindinput="onTopicInput" />

          <view class="field-label" style="margin-top: 10rpx;">章节 Code（可选）</view>
          <input class="input" placeholder="例如：KINEMATICS" value="{{topic.code}}" data-index="{{index}}" data-field="code" bindinput="onTopicInput" />
        </view>
      </block>
    </view>

    <button class="btn-primary" loading="{{saving}}" bindtap="saveSubject">保存</button>
    <button wx:if="{{mode === 'edit'}}" class="btn-outline danger" loading="{{deleting}}" bindtap="deleteSubject">删除科目</button>
  </view>
</view>
