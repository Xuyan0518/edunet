.label {
  font-size: 26rpx;
  color: #334155;
  margin-bottom: 8rpx;
}

.row {
  display: flex;
  gap: 24rpx;
}

.radio-item {
  display: flex;
  align-items: center;
  gap: 8rpx;
  font-size: 28rpx;
}

.input {
  border: 2rpx solid #e2e8f0;
  border-radius: 12rpx;
  padding: 16rpx 20rpx;
  background: #fff;
}

.hint {
  margin-top: 20rpx;
  font-size: 24rpx;
  color: #64748b;
}

.admin-btn {
  margin-top: 16rpx;
}

.signup-hint {
  margin-top: 8rpx;
  color: #dc2626;
}

.avatar-wrapper {
  padding: 0;
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  background: #f1f5f9;
  border: 2rpx solid #e2e8f0;
  overflow: hidden;
  line-height: normal;
  margin: 0;
}

.avatar-wrapper::after {
  border: none;
}

.avatar {
  width: 160rpx;
  height: 160rpx;
  border-radius: 50%;
  display: block;
}

.avatar-hint {
  font-size: 22rpx;
  color: #94a3b8;
  margin-top: 12rpx;
}
