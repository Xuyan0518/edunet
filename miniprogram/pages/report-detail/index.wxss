.summary-text {
  margin-top: 10rpx;
  font-size: 26rpx;
  color: #0f172a;
  line-height: 1.8;
  white-space: pre-wrap;
}

.profile-label {
  display: inline-block;
  background: linear-gradient(135deg, #dbeafe, #e0f2fe);
  color: #1d4ed8;
  border-radius: 999rpx;
  padding: 8rpx 18rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.dashboard-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 12rpx;
}

.metric-card {
  background: linear-gradient(135deg, #eff6ff, #f0f9ff);
  border: 1rpx solid #bfdbfe;
  border-radius: 14rpx;
  padding: 14rpx;
}

.metric-value {
  font-size: 34rpx;
  font-weight: 700;
  color: #0f172a;
}

.metric-label {
  font-size: 22rpx;
  color: #475569;
  margin-top: 4rpx;
}

.activity-row,
.distribution-row,
.trend-row,
.subject-card {
  border: 1rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 14rpx;
  margin-bottom: 12rpx;
  background: #ffffff;
}

.activity-meta {
  font-size: 24rpx;
  color: #334155;
  margin-bottom: 8rpx;
}

.bar-track {
  height: 12rpx;
  background: #e2e8f0;
  border-radius: 999rpx;
  overflow: hidden;
  margin-bottom: 8rpx;
}

.bar-fill {
  height: 100%;
  border-radius: 999rpx;
}

.bar-none {
  background: #cbd5e1;
}

.bar-low {
  background: #60a5fa;
}

.bar-medium {
  background: #2563eb;
}

.bar-high {
  background: #0ea5e9;
}

.subject-title {
  font-size: 28rpx;
  font-weight: 700;
  margin-bottom: 8rpx;
}

.tag-row {
  display: flex;
  flex-wrap: wrap;
  gap: 8rpx;
  margin-top: 8rpx;
}

.tag-strength {
  background: #dcfce7;
  color: #166534;
}

.tag-improve {
  background: #ffedd5;
  color: #9a3412;
}

.tag-next {
  background: #dbeafe;
  color: #1d4ed8;
}

.tag-evidence {
  background: #e2e8f0;
  color: #334155;
}

.field-label {
  margin-top: 12rpx;
  margin-bottom: 6rpx;
  font-size: 24rpx;
  color: #475569;
}

.textarea-compact {
  min-height: 130rpx;
  margin-top: 6rpx;
  line-height: 1.5;
}

.btn-danger-ghost {
  background: #fff1f2;
  color: #b91c1c;
  border: 1rpx solid #fecdd3;
}

.english-skill-grid {
  display: grid;
  grid-template-columns: repeat(1, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 10rpx;
}

.english-skill-card,
.english-vocab-card {
  border: 1rpx solid #dbeafe;
  border-radius: 14rpx;
  padding: 14rpx;
  background: linear-gradient(135deg, #f8fbff, #f0f9ff);
}

.mini-trend {
  margin-top: 8rpx;
  height: 40rpx;
  display: flex;
  align-items: flex-end;
  gap: 6rpx;
}

.mini-bar {
  width: 10rpx;
  border-radius: 6rpx 6rpx 0 0;
  background: linear-gradient(180deg, #2563eb, #38bdf8);
  min-height: 10rpx;
}

.english-ai-list {
  margin-top: 12rpx;
}
