<view class="container admin-page">
  <view class="hero admin-hero">
    <view class="row-between">
      <view>
        <view class="title">管理员数据中心</view>
        <view class="subtitle">学生、用户与审核工作台</view>
      </view>
      <button class="btn-outline refresh-btn" size="mini" bindtap="fetchSummary" loading="{{loading}}">刷新</button>
    </view>
    <view class="cycle-text">本周周期：{{currentCycleText || "加载中"}}</view>
  </view>

  <view class="admin-grid">
    <view class="nav-card primary" bindtap="goStudents">
      <view class="card-label">学生管理</view>
      <view class="card-value">{{metrics.totalStudents || 0}}</view>
      <view class="card-copy">进入学生列表、进度与报告数据</view>
    </view>

    <view class="nav-card" bindtap="goUsers">
      <view class="card-label">用户管理</view>
      <view class="card-value">{{pendingAccessCount}}</view>
      <view class="card-copy">审批账号并分配管理员、教师、家长角色</view>
    </view>

    <view class="nav-card warning" bindtap="goFeedbackReview">
      <view class="card-label">待审批的反馈</view>
      <view class="card-value">{{pendingFeedbackCount}}</view>
      <view class="card-copy">审核老师提交的周、学期、年度反馈</view>
    </view>

    <view class="nav-card" bindtap="goWeeklyPlans">
      <view class="card-label">周计划汇总</view>
      <view class="card-value">{{metrics.incompleteWeeklyPlanRecords || 0}}</view>
      <view class="card-copy">按年级查看本周任务完成、分数与学期统计</view>
    </view>

    <view class="nav-card muted-card">
      <view class="card-label">数据提醒</view>
      <view class="reminder-row">
        <text>缺今日记录</text>
        <text>{{metrics.missingDailyToday || 0}}</text>
      </view>
      <view class="reminder-row">
        <text>缺本周反馈</text>
        <text>{{metrics.missingCurrentWeekly || 0}}</text>
      </view>
    </view>
  </view>
</view>
