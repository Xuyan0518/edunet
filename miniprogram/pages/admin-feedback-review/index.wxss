.toolbar-row {
  display: flex;
  justify-content: flex-end;
  margin: 16rpx 0;
}

.placeholder-copy,
.small-text {
  font-size: 24rpx;
  line-height: 1.55;
}

.empty-card {
  margin-top: 20rpx;
}

.review-card {
  border-color: #bfdbfe;
}

.review-badge {
  flex-shrink: 0;
  border-radius: 999rpx;
  background: #fef3c7;
  color: #b45309;
  font-size: 22rpx;
  font-weight: 700;
  padding: 8rpx 16rpx;
}

.summary-text {
  color: #334155;
  font-size: 26rpx;
  line-height: 1.55;
  margin: 18rpx 0 12rpx;
}

.publish-btn {
  margin-top: 18rpx;
}
