page {
  background: #f5f7fb;
  color: #0f172a;
  font-size: 28rpx;
  font-family: -apple-system, BlinkMacSystemFont, "Helvetica Neue", Helvetica, Arial, "PingFang SC", "Microsoft YaHei", sans-serif;
}

.container {
  padding: 32rpx;
}

.hero {
  background: linear-gradient(135deg, #eef2ff 0%, #f8fafc 100%);
  border-radius: 20rpx;
  padding: 28rpx;
  margin-bottom: 24rpx;
}

.card {
  background: #ffffff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 12rpx 32rpx rgba(15, 23, 42, 0.08);
  border: 1rpx solid #e5eaf3;
}

.title {
  font-size: 42rpx;
  font-weight: 700;
  margin-bottom: 12rpx;
}

.subtitle {
  color: #64748b;
  margin-bottom: 24rpx;
}

.btn-primary {
  background: #2563eb;
  color: #fff;
  border-radius: 14rpx;
  font-weight: 600;
}

.btn-outline {
  border: 2rpx solid #cbd5f5;
  color: #1e293b;
  border-radius: 14rpx;
  background: #fff;
}

.section {
  margin-bottom: 24rpx;
}

.list-item {
  padding: 20rpx 0;
  border-bottom: 1rpx solid #e2e8f0;
}

.tag {
  display: inline-block;
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #e2e8f0;
  color: #334155;
}

.muted {
  color: #64748b;
}

.row {
  display: flex;
  align-items: center;
  gap: 16rpx;
}

.row-between {
  display: flex;
  align-items: center;
  justify-content: space-between;
}

.section-title {
  font-weight: 700;
  font-size: 30rpx;
  margin-bottom: 12rpx;
}

.chip {
  padding: 6rpx 16rpx;
  border-radius: 999rpx;
  font-size: 22rpx;
  background: #f1f5f9;
  color: #475569;
}

.chip-success {
  background: #dcfce7;
  color: #15803d;
}

.chip-warning {
  background: #fef3c7;
  color: #b45309;
}

.chip-muted {
  background: #e2e8f0;
  color: #475569;
}

.divider {
  height: 1rpx;
  background: #e2e8f0;
  margin: 16rpx 0;
}

.pill-group button {
  margin-right: 8rpx;
  margin-bottom: 8rpx;
}

.input {
  border: 2rpx solid #e2e8f0;
  border-radius: 14rpx;
  padding: 16rpx 20rpx;
  background: #fff;
}

.textarea-scroll {
  height: 240rpx;
  line-height: 1.5;
}
