<view class="container">
  <view class="hero">
    <view class="title">管理员面板</view>
    <view class="subtitle">审批与教师管理</view>
  </view>

  <view class="section card">
    <view class="section-title">待审批账号</view>

    <view class="subheader">家长</view>
    <block wx:if="{{pendingParents.length === 0}}">
      <view class="list-item muted">暂无待审批家长</view>
    </block>
    <block wx:else>
      <block wx:for="{{pendingParents}}" wx:key="id">
        <view class="list-item row-between">
          <view class="subject-text">
            <view class="subject-name">{{item.displayName || item.name || "未命名用户"}}</view>
            <view class="muted subject-meta">{{item.wechatOpenIdMasked || "未绑定微信"}}</view>
          </view>
          <view class="row">
            <button class="btn-outline" size="mini" data-id="{{item.id}}" data-role="parent" bindtap="handleApprove">批准</button>
            <button class="btn-outline" size="mini" data-id="{{item.id}}" data-role="parent" bindtap="handleReject">拒绝</button>
          </view>
        </view>
      </block>
    </block>

    <view class="divider"></view>

    <view class="subheader">教师</view>
    <block wx:if="{{pendingTeachers.length === 0}}">
      <view class="list-item muted">暂无待审批教师</view>
    </block>
    <block wx:else>
      <block wx:for="{{pendingTeachers}}" wx:key="id">
        <view class="list-item row-between">
          <view class="subject-text">
            <view class="subject-name">{{item.displayName || item.name || "未命名用户"}}</view>
            <view class="muted subject-meta">{{item.wechatOpenIdMasked || "未绑定微信"}}</view>
          </view>
          <view class="row">
            <button class="btn-outline" size="mini" data-id="{{item.id}}" data-role="teacher" bindtap="handleApprove">批准</button>
            <button class="btn-outline" size="mini" data-id="{{item.id}}" data-role="teacher" bindtap="handleReject">拒绝</button>
          </view>
        </view>
      </block>
    </block>
  </view>

  <view class="section card">
    <view class="row-between">
      <view class="section-title">教师管理</view>
      <view class="muted">删除教师账号</view>
    </view>
    <input class="input" placeholder="搜索教师..." bindinput="onSearchTeacher" />
    <block wx:if="{{filteredTeachers.length === 0}}">
      <view class="list-item muted">暂无教师</view>
    </block>
    <block wx:else>
      <block wx:for="{{filteredTeachers}}" wx:key="id">
        <view class="list-item row-between">
          <view class="subject-text">
            <view class="subject-name">{{item.displayName || item.name || "未命名用户"}}</view>
            <view class="muted subject-meta">{{item.wechatOpenIdMasked || "未绑定微信"}} · {{item.status}}</view>
          </view>
          <button class="btn-outline" size="mini" data-id="{{item.id}}" bindtap="deleteTeacher">删除</button>
        </view>
      </block>
    </block>
  </view>
</view>
