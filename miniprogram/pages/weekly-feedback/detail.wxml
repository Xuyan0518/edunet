<view class="container">
  <view class="hero">
    <view class="title">每周汇报</view>
    <view class="subtitle">{{student.name}} · {{weekStarting}} - {{weekEnding}}</view>
    <view class="row" wx:if="{{isTeacher && existingId && !isEditing}}">
      <button class="btn-outline" size="mini" bindtap="startEdit">编辑</button>
    </view>
  </view>

  <view class="section card">
    <view class="section-title">周次（周日）</view>
    <picker mode="selector" range="{{sundayOptions}}" value="{{sundayIndex}}" bindchange="onSundayPick" disabled="{{!isEditable}}">
      <view class="chip">{{weekStarting}}</view>
    </picker>
    <view class="muted" style="margin-top: 12rpx;">结束日期：{{weekEnding}}</view>
  </view>

  <view class="section card">
    <view class="section-title">每日进度</view>
    <block wx:if="{{progressLoading}}">
      <view class="muted">加载中...</view>
    </block>
    <block wx:if="{{!progressLoading && progressEntries.length === 0}}">
      <view class="muted">本周暂无每日进度</view>
    </block>
    <block wx:for="{{progressEntries}}" wx:for-item="day" wx:for-index="dayIndex" wx:key="id">
      <view class="daily-card {{dayIndex % 2 === 1 ? 'daily-card-alt' : ''}} {{day.isAbsentDay ? 'daily-card-absent' : day.attendance === 'late' ? 'daily-card-late' : 'daily-card-present'}} {{expandedProgressMap[day.id || day.date] ? 'daily-card-expanded' : ''}}">
        <view class="row-between daily-head" data-key="{{day.id || day.date}}" bindtap="toggleProgressEntry">
          <view class="daily-title-area">
            <view class="title-small">{{day.date}}</view>
            <view class="muted daily-preview">{{day.previewText}}</view>
          </view>
          <view class="daily-actions">
            <view class="status-chip {{day.isAbsentDay ? 'status-chip-absent' : day.attendance === 'late' ? 'status-chip-late' : 'status-chip-present'}}">{{day.attendanceLabel}}</view>
            <view class="toggle-text">{{expandedProgressMap[day.id || day.date] ? "收起" : "展开"}}</view>
          </view>
        </view>
        <view class="daily-time" wx:if="{{!day.isAbsentDay && (day.attendanceStart || day.attendanceEnd)}}">
          时间 {{day.attendanceStart || "--"}} - {{day.attendanceEnd || "--"}}
        </view>
        <block wx:if="{{expandedProgressMap[day.id || day.date]}}">
          <view wx:if="{{day.isAbsentDay}}" class="absent-day-block">
            <view class="absent-label">缺席</view>
            <view wx:if="{{day.absenceReason}}" class="muted">原因：{{day.absenceReason}}</view>
          </view>
          <block wx:for="{{day.activities}}" wx:for-item="activity" wx:key="index">
            <view class="activity-card">
              <view class="row-between">
                <view class="field-label">{{activity.subjectDisplayName || activity.subjectName || "科目"}}</view>
                <view wx:if="{{!isTeacher && activity.type === 'english'}}" class="chip">英文</view>
              </view>
              <view class="activity-summary" wx:if="{{activity.showSummaryLine}}">{{activity.summaryLine}}</view>
              <block wx:for="{{activity.sections}}" wx:for-item="section" wx:key="index">
                <view class="section-block">
                  <view class="section-block-title">{{section.title}}</view>
                  <block wx:if="{{section.kind === 'scored'}}">
                    <view class="mini-meta">
                      <view>{{section.countLabel}}：{{section.countValue}}</view>
                    </view>
                    <block wx:for="{{section.list}}" wx:for-item="exercise" wx:key="index">
                      <view class="exercise-row">
                        <view class="exercise-head">
                          <view class="muted">{{exercise.title}}</view>
                          <view class="score-pill">得分 {{exercise.scoreText}}</view>
                        </view>
                        <view wx:if="{{exercise.problems}}" class="exercise-note">
                          <view class="exercise-note-label">出现的问题/失分点</view>
                          <view>{{exercise.problems}}</view>
                        </view>
                      </view>
                    </block>
                  </block>
                  <block wx:if="{{section.kind === 'kv'}}">
                    <block wx:for="{{section.rows}}" wx:for-item="row" wx:key="index">
                      <view class="narrative-item">
                        <view class="narrative-label">{{row.label}}</view>
                        <view class="narrative-value">{{row.value}}</view>
                      </view>
                    </block>
                  </block>
                  <view wx:if="{{section.note}}" class="section-note">{{section.note}}</view>
                </view>
              </block>
              <block wx:if="{{activity.papers && activity.papers.length}}">
                <view class="paper-title">试卷 / 测验</view>
                <block wx:for="{{activity.papers}}" wx:for-item="paper" wx:key="index">
                  <view class="paper-item">
                    <view class="row-between">
                      <view>{{paper.date}} · {{paper.title}}</view>
                      <view class="score-badge">{{paper.scoreText}}</view>
                    </view>
                    <view class="muted" wx:if="{{isTeacher && (paper.typeName || paper.schoolName)}}">
                      {{paper.typeName || "--"}} · {{paper.schoolName || "--"}}
                    </view>
                    <view class="muted" wx:if="{{isTeacher && paper.strengths}}">做得好的地方：{{paper.strengths}}</view>
                    <view class="muted" wx:if="{{isTeacher && paper.improvements}}">需要改进的地方：{{paper.improvements}}</view>
                  </view>
                </block>
              </block>
            </view>
          </block>
          <view wx:if="{{!day.isAbsentDay && day.summary}}" class="daily-summary">
            <view class="field-label">当日总结</view>
            <view class="muted">{{day.summary}}</view>
          </view>
        </block>
      </view>
    </block>
  </view>

  <view class="section card">
    <view class="section-title">本周试卷 / 测验</view>
    <block wx:if="{{weeklyPapersLoading}}">
      <view class="muted">加载中...</view>
    </block>
    <block wx:if="{{!weeklyPapersLoading && weeklyPaperGroups.length === 0}}">
      <view class="muted">本周暂无试卷/测验记录</view>
    </block>
    <block wx:for="{{weeklyPaperGroups}}" wx:key="subjectDisplayName">
      <view class="paper-group-card">
        <view class="row-between">
          <view class="field-label">{{item.subjectDisplayName}}</view>
          <view class="chip">{{item.count}} 份</view>
        </view>
        <block wx:for="{{item.papers}}" wx:key="id" wx:for-item="paper">
          <view class="paper-item">
            <view class="row-between">
              <view>{{paper.date}} · {{paper.title}}</view>
              <view class="score-badge">{{paper.scoreText}}</view>
            </view>
            <view class="muted" wx:if="{{isTeacher && (paper.typeName || paper.schoolName)}}">
              {{paper.typeName || "--"}} · {{paper.schoolName || "--"}}
            </view>
            <view class="muted" wx:if="{{isTeacher && paper.strengths}}">做得好的地方：{{paper.strengths}}</view>
            <view class="muted" wx:if="{{isTeacher && paper.improvements}}">需要改进的地方：{{paper.improvements}}</view>
          </view>
        </block>
      </view>
    </block>
  </view>

  <view class="section card">
    <view class="section-title">汇总栏</view>
    <view wx:if="{{isEditable && lastUpdatedAtText}}" class="muted" style="margin-top: 6rpx;">
      最后修改：{{lastUpdatedAtText}} · {{lastUpdatedBy || "未知老师"}}
    </view>
    <view class="field-label">整体总结</view>
    <textarea class="input textarea-scroll" placeholder="填写总结..." value="{{summary}}" bindinput="onFieldInput" data-field="summary" disabled="{{!isEditable}}" maxlength="-1"></textarea>
    <view class="row" style="margin-top: 12rpx;">
      <button wx:if="{{isEditable}}" class="btn-outline" size="mini" bindtap="generateSummary" disabled="{{aiLoading}}">
        {{aiLoading ? "生成中..." : "自动生成"}}
      </button>
      <button class="btn-outline" size="mini" bindtap="openSummaryView" disabled="{{!summary}}">
        查看全文
      </button>
    </view>
  </view>

  <view class="row">
    <button wx:if="{{isEditable}}" class="btn-outline" bindtap="cancelEdit">取消</button>
    <button wx:if="{{isEditable}}" class="btn-primary" bindtap="save">保存</button>
  </view>

  <button wx:if="{{existingId && isTeacher}}" class="btn-outline" bindtap="deleteEntry">删除反馈</button>
</view>
