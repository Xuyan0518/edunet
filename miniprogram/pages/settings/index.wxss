.btn-outline {
  margin-top: 24rpx;
}

.small-btn {
  margin-top: 16rpx;
}

.edit-wrap {
  margin-top: 20rpx;
  padding: 16rpx;
  border: 1rpx solid #e2e8f0;
  border-radius: 16rpx;
  background: #f8fafc;
}

.name-input {
  width: 100%;
  box-sizing: border-box;
  height: 88rpx;
  line-height: 88rpx;
  padding: 0 20rpx;
  font-size: 30rpx;
  color: #0f172a;
  border: 2rpx solid #cbd5e1;
  border-radius: 14rpx;
  background: #fff;
}

.edit-actions {
  display: flex;
  gap: 16rpx;
  margin-top: 16rpx;
}

.inline-btn {
  flex: 1;
  margin-top: 0;
  height: 76rpx;
  line-height: 76rpx;
  font-size: 30rpx;
}
