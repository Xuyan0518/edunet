<view class="container">
  <view class="hero">
    <view class="row-between">
      <view>
        <view class="title">学生</view>
        <view class="subtitle">选择学生查看详情</view>
      </view>
      <button wx:if="{{isTeacher}}" class="btn-primary" size="mini" bindtap="goAdd">新增学生</button>
    </view>
    <input class="input" placeholder="搜索学生..." bindinput="onSearch" />
    <view wx:if="{{isTeacher}}" class="filter-bar">
      <view class="row-between">
        <view class="filter-label">年级筛选</view>
        <picker mode="selector" range="{{gradeOptions}}" value="{{gradeIndex}}" bindchange="onGradeChange">
          <view class="chip">{{gradeOptions[gradeIndex]}}</view>
        </picker>
      </view>
    </view>
  </view>

  <view class="card">
    <block wx:if="{{loading}}">
      <view class="list-item">加载中...</view>
    </block>
    <block wx:elif="{{filtered.length === 0}}">
      <view class="list-item">暂无学生</view>
    </block>
    <block wx:else>
      <block wx:for="{{filtered}}" wx:key="id">
        <view class="list-item row-between" bindtap="goDetail" data-id="{{item.id}}">
          <view>
            <view>{{item.name}}</view>
            <view class="muted">年级 {{item.grade}}</view>
          </view>
          <view class="chip">查看</view>
        </view>
      </block>
    </block>
  </view>
</view>
