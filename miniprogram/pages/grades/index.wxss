.field-label {
  font-size: 24rpx;
  color: #475569;
  margin: 12rpx 0 6rpx;
}

.grade-label {
  font-weight: 600;
}

.subject-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-bottom: 12rpx;
}

.subject-name {
  width: 180rpx;
  font-weight: 600;
  color: #1e293b;
}

.subject-input {
  flex: 1;
}

.custom-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  margin-top: 8rpx;
}

.exam-card {
  margin-top: 16rpx;
  padding: 16rpx;
  border-radius: 16rpx;
  border: 1rpx solid #e2e8f0;
  background: #f8fafc;
}
