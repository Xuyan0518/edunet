<view class="container">
  <view class="hero">
    <view class="title">学习报告</view>
    <view class="subtitle">{{student.name || '学生'}} · 报告中心</view>
    <view class="muted" wx:if="{{isManager && parseWarning}}">{{parseWarning}}</view>
  </view>

  <view class="section card" wx:if="{{isManager}}">
    <view class="section-title">生成报告</view>
    <view class="field-label">学期报告日期范围</view>
    <view class="row-between">
      <picker mode="date" value="{{quarterlyStartDate}}" bindchange="onQuarterStartChange">
        <view class="chip">{{quarterlyStartDate || '开始日期'}}</view>
      </picker>
      <picker mode="date" value="{{quarterlyEndDate}}" bindchange="onQuarterEndChange">
        <view class="chip">{{quarterlyEndDate || '结束日期'}}</view>
      </picker>
    </view>
    <view class="row" style="margin-top: 12rpx;">
      <button class="btn-primary" size="mini" bindtap="generateQuarterly" disabled="{{generatingQuarterly}}">
        {{generatingQuarterly ? '生成中...' : '生成学期报告'}}
      </button>
    </view>

    <view class="divider"></view>
    <view class="field-label">年度报告年份</view>
    <picker mode="selector" range="{{generateYearOptions}}" value="{{generateYearIndex}}" bindchange="onGenerateYearChange">
      <view class="chip">{{generateYearOptions[generateYearIndex] || '选择年份'}}</view>
    </picker>
    <view class="row" style="margin-top: 12rpx;">
      <button class="btn-primary" size="mini" bindtap="generateYearly" disabled="{{generatingYearly}}">
        {{generatingYearly ? '生成中...' : '生成年度报告'}}
      </button>
    </view>
  </view>

  <view class="section card">
    <view class="section-title" style="margin-bottom: 8rpx;">报告列表</view>
    <view class="filter-bar">
      <picker mode="selector" range="{{reportTypeOptions}}" value="{{reportTypeIndex}}" bindchange="onReportTypeChange">
        <view class="chip filter-chip">{{reportTypeOptions[reportTypeIndex]}}</view>
      </picker>
      <picker mode="selector" range="{{yearOptions}}" value="{{yearIndex}}" bindchange="onYearFilterChange">
        <view class="chip filter-chip">{{yearOptions[yearIndex]}}</view>
      </picker>
      <picker wx:if="{{isManager}}" mode="selector" range="{{visibleFilterOptions}}" value="{{visibleFilterIndex}}" bindchange="onVisibleFilterChange">
        <view class="chip filter-chip">{{visibleFilterOptions[visibleFilterIndex]}}</view>
      </picker>
    </view>

    <block wx:if="{{loading}}">
      <view class="muted">加载中...</view>
    </block>
    <block wx:elif="{{reports.length === 0}}">
      <view class="empty-card">
        <view class="empty-title">暂无学习报告</view>
        <view class="muted">{{isManager ? '你可以生成一份学期报告或年度报告。' : '老师暂未发布学习报告。'}}</view>
      </view>
    </block>
    <block wx:else>
      <block wx:for="{{reports}}" wx:key="id">
        <view class="report-card">
          <view class="row-between report-head">
            <view class="report-title">{{item.title || (item.reportType === 'yearly' ? '年度学习报告' : '学期学习报告')}}</view>
            <view class="row report-badges">
              <view class="state-badge {{item.status === 'final' ? 'state-final' : 'state-draft'}}">{{item.status === 'final' ? '最终版' : '草稿'}}</view>
              <view class="state-badge {{item.visibleToParent ? 'state-visible' : 'state-hidden'}}">{{item.visibleToParent ? '已发布' : '未发布'}}</view>
            </view>
          </view>
          <view class="report-meta">
            {{item.reportType === 'yearly' ? '年度报告' : '学期报告'}} · {{item.startDate || '--'}} - {{item.endDate || '--'}}
          </view>
          <view class="report-meta" wx:if="{{item.year}}">年份：{{item.year}}</view>
          <view class="report-preview">{{item.summaryPreview || item.summary || '暂无摘要'}}</view>
          <view class="report-foot">
            <view class="report-updated">{{item.updatedAtText || item.createdAtText || '--'}}{{item.updatedByName ? ' · ' + item.updatedByName : ''}}</view>
            <view class="report-actions">
              <button class="btn-primary-light" size="mini" data-id="{{item.id}}" bindtap="openReport">查看</button>
              <button
                wx:if="{{isManager}}"
                class="btn-outline"
                size="mini"
                data-id="{{item.id}}"
                data-visible="{{item.visibleToParent}}"
                bindtap="toggleVisibility"
              >{{item.visibleToParent ? '取消发布' : '发布给家长'}}</button>
              <button
                wx:if="{{isManager}}"
                class="btn-danger-ghost"
                size="mini"
                data-id="{{item.id}}"
                bindtap="deleteReportItem"
                loading="{{deletingId === item.id}}"
              >删除</button>
            </view>
          </view>
        </view>
      </block>
    </block>
  </view>
</view>
